---
interface Props {
  videoId: string;
}
const { videoId } = Astro.props;
---

<section class="video">
  <div class="inner">
    <h2>See the backcountry</h2>
    <div class="frame">
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${videoId}`}
        title="Archer Airboat Tours overview"
        loading="lazy"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .video { background: var(--sand-deep); padding: var(--space-section) 1.25rem; }
  .inner { max-width: 56rem; margin: 0 auto; }
  h2 { font-family: var(--font-display); font-size: var(--step-3); font-weight: 560; margin: 0 0 1.5rem; }
  .frame { position: relative; aspect-ratio: 16 / 9; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-soft); }
  .frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>
